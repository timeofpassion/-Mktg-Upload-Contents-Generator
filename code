<!DOCTYPE html>
<html lang="ko">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>SNS 콘텐츠 카피 생성기 | 열정의시간</title>
<link href="https://fonts.googleapis.com/css2?family=Noto+Sans+KR:wght@400;500;700&display=swap" rel="stylesheet">
<style>
*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
:root {
  --bg: #F7F7F5; --surface: #FFFFFF; --surface2: #F2F2F0;
  --border: #E5E5E2; --text: #1A1A1A; --muted: #888; --radius: 12px;
}
body { background: var(--bg); color: var(--text); font-family: 'Noto Sans KR', sans-serif; min-height: 100vh; padding: 40px 20px 80px; }
.container { max-width: 680px; margin: 0 auto; }
.header { margin-bottom: 36px; }
.header h1 { font-size: 22px; font-weight: 700; letter-spacing: -0.5px; margin-bottom: 6px; }
.header p { font-size: 13px; color: var(--muted); line-height: 1.6; }

/* API Key Banner */
.api-banner {
  background: #FFF8E1; border: 1px solid #FFE082;
  border-radius: var(--radius); padding: 16px 20px;
  margin-bottom: 20px; display: flex; align-items: center; gap: 12px;
}
.api-banner.set { background: #F1F8E9; border-color: #A5D6A7; }
.api-banner-icon { font-size: 18px; flex-shrink: 0; }
.api-banner-body { flex: 1; }
.api-banner-body p { font-size: 12px; color: #5D4037; margin-bottom: 8px; line-height: 1.5; }
.api-banner.set .api-banner-body p { color: #2E7D32; margin-bottom: 0; }
.api-key-row { display: flex; gap: 8px; }
.api-key-input {
  flex: 1; padding: 8px 12px; font-size: 13px;
  border: 1px solid #FFD54F; border-radius: 7px;
  background: #fff; color: var(--text);
  font-family: 'Noto Sans KR', sans-serif; outline: none;
}
.api-key-input:focus { border-color: #FFA000; }
.api-save-btn {
  padding: 8px 16px; font-size: 12px; font-weight: 600;
  background: #1A1A1A; color: #fff; border: none;
  border-radius: 7px; cursor: pointer; font-family: 'Noto Sans KR', sans-serif;
  white-space: nowrap;
}
.api-save-btn:hover { background: #333; }
.api-change-btn {
  padding: 6px 12px; font-size: 12px;
  background: transparent; color: #2E7D32;
  border: 1px solid #A5D6A7; border-radius: 7px;
  cursor: pointer; font-family: 'Noto Sans KR', sans-serif;
}

.card { background: var(--surface); border: 1px solid var(--border); border-radius: var(--radius); padding: 24px; margin-bottom: 14px; }
.card-title { font-size: 11px; font-weight: 700; text-transform: uppercase; letter-spacing: 1.2px; color: var(--muted); margin-bottom: 14px; display: flex; align-items: center; gap: 6px; }
.card-title .num { width: 18px; height: 18px; border-radius: 50%; background: var(--text); color: #fff; font-size: 10px; display: flex; align-items: center; justify-content: center; }
.field { margin-bottom: 12px; }
.field:last-child { margin-bottom: 0; }
.field label { display: block; font-size: 12px; color: var(--muted); margin-bottom: 5px; font-weight: 500; }
input[type=text], textarea { width: 100%; padding: 10px 13px; font-size: 14px; border: 1px solid var(--border); border-radius: 8px; background: var(--surface2); color: var(--text); font-family: 'Noto Sans KR', sans-serif; outline: none; transition: border-color .15s; }
input[type=text]:focus, textarea:focus { border-color: #aaa; background: #fff; }
input[type=text]::placeholder, textarea::placeholder { color: #bbb; }
textarea { resize: none; line-height: 1.6; }
.topic-wrap { position: relative; }
.topic-textarea { padding-bottom: 42px !important; }
.upgrade-btn { position: absolute; bottom: 9px; right: 9px; padding: 5px 12px; font-size: 11px; font-weight: 600; border: 1px solid var(--border); border-radius: 6px; background: var(--surface); color: var(--text); cursor: pointer; font-family: 'Noto Sans KR', sans-serif; display: flex; align-items: center; gap: 4px; transition: all .15s; }
.upgrade-btn:hover { border-color: #aaa; }
.upgrade-btn:disabled { opacity: 0.4; cursor: not-allowed; }
.chips { display: flex; flex-wrap: wrap; gap: 7px; }
.chip { padding: 7px 14px; font-size: 12px; border-radius: 20px; border: 1px solid var(--border); background: var(--surface2); color: var(--muted); cursor: pointer; transition: all .15s; user-select: none; }
.chip:hover { border-color: #aaa; color: var(--text); }
.chip.on { background: var(--text); border-color: var(--text); color: #fff; font-weight: 600; }
.gen-btn { width: 100%; padding: 15px; margin-top: 6px; background: var(--text); color: #fff; border: none; border-radius: var(--radius); font-size: 15px; font-weight: 700; cursor: pointer; font-family: 'Noto Sans KR', sans-serif; transition: opacity .15s, transform .1s; }
.gen-btn:hover { opacity: 0.85; }
.gen-btn:active { transform: scale(0.99); }
.gen-btn:disabled { opacity: 0.3; cursor: not-allowed; }
.plat-strip { display: flex; gap: 6px; flex-wrap: wrap; margin-top: 12px; justify-content: center; }
.plat-tag { padding: 4px 12px; border-radius: 20px; font-size: 11px; border: 1px solid var(--border); color: var(--muted); background: var(--surface); }
#resultArea { margin-top: 28px; display: none; }
.result-header { display: flex; align-items: center; justify-content: space-between; margin-bottom: 14px; }
.result-label { font-size: 12px; font-weight: 700; color: var(--muted); text-transform: uppercase; letter-spacing: 1px; }
.regen-btn { padding: 6px 14px; font-size: 12px; border: 1px solid var(--border); border-radius: 8px; background: var(--surface); color: var(--muted); cursor: pointer; font-family: 'Noto Sans KR', sans-serif; transition: all .15s; }
.regen-btn:hover { border-color: #aaa; color: var(--text); }
.plat-tabs { display: flex; gap: 6px; flex-wrap: wrap; margin-bottom: 14px; }
.plat-tab { padding: 7px 16px; border-radius: 20px; font-size: 12px; font-weight: 600; border: 1px solid var(--border); background: var(--surface2); color: var(--muted); cursor: pointer; transition: all .15s; display: flex; align-items: center; gap: 6px; }
.plat-tab .dot { width: 7px; height: 7px; border-radius: 50%; background: var(--pc); }
.plat-tab.on { border-color: var(--pc); background: #fff; color: var(--text); }
.panels > div { display: none; }
.panels > div.show { display: block; animation: fadeUp .2s ease; }
@keyframes fadeUp { from { opacity:0; transform:translateY(6px); } to { opacity:1; transform:translateY(0); } }
.res-card { background: var(--surface); border: 1px solid var(--border); border-radius: var(--radius); overflow: hidden; }
.sec { padding: 16px 20px; border-bottom: 1px solid var(--border); }
.sec:last-child { border-bottom: none; }
.sec-key { font-size: 10px; font-weight: 700; text-transform: uppercase; letter-spacing: 1.2px; color: var(--muted); margin-bottom: 10px; }
.sec-val { font-size: 14px; line-height: 1.75; color: var(--text); white-space: pre-wrap; }
.title-rows { display: flex; flex-direction: column; gap: 8px; }
.title-row { display: flex; align-items: flex-start; gap: 10px; padding: 10px 12px; background: var(--surface2); border-radius: 8px; }
.t-num { font-size: 10px; font-weight: 700; color: #fff; border-radius: 4px; padding: 2px 7px; flex-shrink: 0; margin-top: 2px; }
.t-txt { font-size: 14px; font-weight: 600; line-height: 1.5; flex: 1; }
.tags { display: flex; flex-wrap: wrap; gap: 6px; }
.tag { padding: 4px 11px; border-radius: 20px; background: var(--surface2); border: 1px solid var(--border); font-size: 12px; color: var(--muted); }
.copy-row { display: flex; justify-content: flex-end; margin-top: 10px; }
.cp { padding: 4px 12px; font-size: 11px; border: 1px solid var(--border); border-radius: 6px; background: transparent; color: var(--muted); cursor: pointer; font-family: 'Noto Sans KR', sans-serif; transition: all .15s; }
.cp:hover { border-color: #aaa; color: var(--text); }
.cp.ok { border-color: #4CAF50; color: #4CAF50; }
.loading-box { padding: 48px; text-align: center; }
.spinner { width: 28px; height: 28px; border: 2px solid var(--border); border-top-color: var(--text); border-radius: 50%; animation: spin .7s linear infinite; margin: 0 auto 14px; }
@keyframes spin { to { transform: rotate(360deg); } }
.loading-box p { font-size: 13px; color: var(--muted); }
.err-box { background: #FFF0F0; border: 1px solid #FFD0D0; border-radius: 8px; padding: 14px 18px; color: #CC3333; font-size: 13px; line-height: 1.6; }
footer { margin-top: 48px; text-align: center; font-size: 12px; color: #ccc; }
</style>
</head>
<body>
<div class="container">

  <div class="header">
    <h1>SNS 콘텐츠 카피 생성기</h1>
    <p>병원 정보와 주제를 입력하면 YouTube, 네이버TV, Instagram, TikTok, Facebook<br>5개 채널 SEO 최적화 카피를 자동으로 생성합니다.</p>
  </div>

  <!-- API Key Banner -->
  <div class="api-banner" id="apiBanner">
    <div class="api-banner-icon">🔑</div>
    <div class="api-banner-body">
      <p>사용하려면 Anthropic API 키를 입력하세요. 키는 이 브라우저에만 저장되며 외부로 전송되지 않습니다.<br>API 키 발급: <a href="https://console.anthropic.com" target="_blank" style="color:#E65100;">console.anthropic.com</a> → API Keys → Create Key</p>
      <div class="api-key-row">
        <input type="password" class="api-key-input" id="apiKeyInput" placeholder="sk-ant-api03-..." />
        <button class="api-save-btn" onclick="saveApiKey()">저장</button>
      </div>
    </div>
  </div>

  <!-- STEP 1 -->
  <div class="card">
    <div class="card-title"><div class="num">1</div>병원 정보</div>
    <div class="field">
      <label>병원명</label>
      <input type="text" id="hospital" placeholder="예: 멜로우피부과 신사점" />
    </div>
    <div class="field">
      <label>원장명 및 전문 분야</label>
      <input type="text" id="doctor" placeholder="예: 고영욱 원장 / 온다리프팅 전문" />
    </div>
  </div>

  <!-- STEP 2 -->
  <div class="card">
    <div class="card-title"><div class="num">2</div>콘텐츠 주제</div>
    <div class="field">
      <div class="topic-wrap">
        <textarea class="topic-textarea" id="topic" rows="4" placeholder="예: 온다리프팅 효과 및 부작용 안내&#10;간단히 입력 후 '주제 업그레이드' 버튼을 누르면 더 풍부하게 다듬어드려요."></textarea>
        <button class="upgrade-btn" id="upgradeBtn" onclick="upgradeTopic()">✦ 주제 업그레이드</button>
      </div>
    </div>
  </div>

  <!-- STEP 3 -->
  <div class="card">
    <div class="card-title"><div class="num">3</div>톤앤매너 스타일</div>
    <div class="chips">
      <div class="chip on" data-val="전문적이고 신뢰감 있는">전문/신뢰</div>
      <div class="chip" data-val="친근하고 따뜻한">친근/따뜻</div>
      <div class="chip" data-val="감성적이고 스토리텔링 중심의">감성/스토리</div>
      <div class="chip" data-val="트렌디하고 MZ세대에게 어필하는">트렌디/MZ</div>
      <div class="chip" data-val="유머러스하고 재치있는">유머/재치</div>
      <div class="chip" data-val="고급스럽고 프리미엄 이미지의">프리미엄</div>
      <div class="chip" data-val="정보 중심의 교육적인">정보/교육</div>
    </div>
  </div>

  <button class="gen-btn" id="genBtn" onclick="generate()">5개 채널 카피 한번에 생성하기 →</button>
  <div class="plat-strip">
    <span class="plat-tag">YouTube</span><span class="plat-tag">네이버TV</span>
    <span class="plat-tag">Instagram</span><span class="plat-tag">TikTok</span><span class="plat-tag">Facebook</span>
  </div>

  <div id="resultArea">
    <div class="result-header">
      <span class="result-label">생성 결과</span>
      <button class="regen-btn" onclick="generate()">↺ 다시 생성</button>
    </div>
    <div class="plat-tabs" id="platTabs"></div>
    <div class="panels" id="panels"></div>
  </div>

  <footer>열정의시간 마케팅팀 내부용</footer>
</div>

<script>
const PLATS = [
  { id: 'youtube',   label: 'YouTube',   color: '#FF0000' },
  { id: 'navertv',   label: '네이버TV',  color: '#03C75A' },
  { id: 'instagram', label: 'Instagram', color: '#E1306C' },
  { id: 'tiktok',    label: 'TikTok',    color: '#000000' },
  { id: 'facebook',  label: 'Facebook',  color: '#1877F2' },
];

// API Key 관리 - 브라우저 localStorage에만 저장
function getApiKey() { return localStorage.getItem('sns_api_key') || ''; }

function saveApiKey() {
  const key = document.getElementById('apiKeyInput').value.trim();
  if (!key.startsWith('sk-ant-')) { alert('올바른 API 키 형식이 아닙니다. sk-ant-로 시작해야 합니다.'); return; }
  localStorage.setItem('sns_api_key', key);
  renderApiBanner(true);
}

function renderApiBanner(isSet) {
  const banner = document.getElementById('apiBanner');
  if (isSet) {
    banner.className = 'api-banner set';
    banner.innerHTML = `
      <div class="api-banner-icon">✅</div>
      <div class="api-banner-body">
        <p>API 키가 설정되어 있습니다. 이 브라우저에만 저장됩니다.</p>
      </div>
      <button class="api-change-btn" onclick="resetApiKey()">변경</button>`;
  }
}

function resetApiKey() {
  localStorage.removeItem('sns_api_key');
  const banner = document.getElementById('apiBanner');
  banner.className = 'api-banner';
  banner.innerHTML = `
    <div class="api-banner-icon">🔑</div>
    <div class="api-banner-body">
      <p>사용하려면 Anthropic API 키를 입력하세요. 키는 이 브라우저에만 저장되며 외부로 전송되지 않습니다.<br>API 키 발급: <a href="https://console.anthropic.com" target="_blank" style="color:#E65100;">console.anthropic.com</a> → API Keys → Create Key</p>
      <div class="api-key-row">
        <input type="password" class="api-key-input" id="apiKeyInput" placeholder="sk-ant-api03-..." />
        <button class="api-save-btn" onclick="saveApiKey()">저장</button>
      </div>
    </div>`;
}

// 페이지 로드 시 저장된 키 확인
window.addEventListener('load', () => {
  if (getApiKey()) renderApiBanner(true);
});

document.querySelectorAll('.chip').forEach(c => {
  c.addEventListener('click', () => {
    document.querySelectorAll('.chip').forEach(x => x.classList.remove('on'));
    c.classList.add('on');
  });
});

function getTone() { return document.querySelector('.chip.on')?.dataset.val || '전문적이고 신뢰감 있는'; }

async function callClaude(prompt, maxTokens = 1500) {
  const apiKey = getApiKey();
  if (!apiKey) { alert('먼저 API 키를 입력하고 저장해주세요.'); throw new Error('API 키 없음'); }
  const res = await fetch('https://api.anthropic.com/v1/messages', {
    method: 'POST',
    headers: {
      'Content-Type': 'application/json',
      'x-api-key': apiKey,
      'anthropic-version': '2023-06-01',
      'anthropic-dangerous-direct-browser-access': 'true'
    },
    body: JSON.stringify({ model: 'claude-sonnet-4-20250514', max_tokens: maxTokens, messages: [{ role: 'user', content: prompt }] })
  });
  if (!res.ok) {
    const err = await res.json().catch(() => ({}));
    throw new Error(err?.error?.message || `API 오류 ${res.status}`);
  }
  const data = await res.json();
  return data.content?.find(b => b.type === 'text')?.text || '';
}

function buildPrompt(hospital, doctor, topic, platform) {
  const tone = getTone();
  const base = `당신은 의료 SNS 마케팅 전문 카피라이터입니다.
병원명: ${hospital}
원장: ${doctor || '미입력'}
콘텐츠 주제: ${topic}
톤앤매너: ${tone} 톤으로 작성
반드시 순수 JSON만 반환하세요. 마크다운, 코드블록, 설명 없이 JSON 객체만 출력하세요.`;

  const schemas = {
    youtube: base + `\n\n출력 JSON:\n{"titles":["후킹 포인트 있는 제목1(25~35자)","제목2","제목3"],"description":"설명란 200자 이상 — 핵심 키워드 포함, 시술 정보 상세 안내, CTA 포함","timeline":[{"time":"00:00","label":"인트로"},{"time":"00:45","label":"챕터2"},{"time":"01:30","label":"챕터3"},{"time":"02:30","label":"챕터4"},{"time":"03:30","label":"챕터5"},{"time":"04:30","label":"마무리"}],"hashtags":["태그1","태그2","태그3","태그4","태그5","태그6","태그7","태그8","태그9","태그10","태그11","태그12"]}\n규칙: titles는 마케팅 후킹 포인트 포함. timeline 챕터명은 주제에 맞게. hashtags는 # 없이.`,
    navertv: base + `\n\n출력 JSON:\n{"titles":["후킹 포인트 있는 제목1(20~30자)","제목2","제목3"],"description":"소개글 — 네이버 검색 키워드 자연 삽입, 3~4문장 상세 작성","hashtags":["태그1","태그2","태그3","태그4","태그5","태그6","태그7","태그8"]}\n규칙: titles는 네이버 검색 최적화 + 후킹 포인트. hashtags는 # 없이.`,
    instagram: base + `\n\n출력 JSON:\n{"hook":"SEO 후킹 문구 첫 1~2줄 (이모지 없이, 궁금증 유발)","caption":"본문 캡션 4~5줄 (이모지 없이, 정보 전달 + 공감)","cta":"저장/공유/댓글 유도 1줄 (이모지 없이)","hashtags":["태그1","태그2","태그3","태그4","태그5","태그6","태그7","태그8","태그9","태그10","태그11","태그12","태그13","태그14","태그15","태그16","태그17","태그18"]}\n규칙: 이모지 절대 사용 금지. hashtags는 # 없이.`,
    tiktok: base + `\n\n출력 JSON:\n{"hook":"첫 3초 후킹 텍스트 (이모지 없이, 짧고 강렬하게)","caption":"본문 캡션 2~3줄 (이모지 없이, MZ 감성 + SEO)","hashtags":["태그1","태그2","태그3","태그4","태그5","태그6","태그7"]}\n규칙: 이모지 절대 사용 금지. hashtags는 # 없이.`,
    facebook: base + `\n\n출력 JSON:\n{"hook":"뉴스피드 클릭 유도 첫 문장 (후킹 포인트 포함)","body":"본문 5~6줄 — 정보 전달 + 신뢰감 + 브랜드 스토리","cta":"링크 클릭/댓글/공유 유도 1줄","hashtags":["태그1","태그2","태그3","태그4","태그5"]}\n규칙: hashtags는 # 없이.`
  };
  return schemas[platform];
}

function safeParseJSON(raw) {
  let s = raw.trim().replace(/^```[\w]*\n?/m,'').replace(/```$/m,'').trim();
  const m = s.match(/\{[\s\S]*\}/);
  if (m) s = m[0];
  return JSON.parse(s);
}

function esc(s) { return String(s).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;'); }
function escA(s) { return String(s).replace(/"/g,'&quot;').replace(/'/g,'&#39;'); }
let _cc = 0;

function makeSection(label, html, copyVal) {
  const id = 'cp' + (_cc++);
  return `<div class="sec"><div class="sec-key">${label}</div>${html}<div class="copy-row"><button class="cp" id="${id}" data-v="${escA(copyVal)}" onclick="doCopy('${id}')">복사</button></div></div>`;
}

function renderPanel(platId, color, data) {
  let html = '<div class="res-card">';
  if (data.titles?.length) {
    const rows = data.titles.map((t,i) => `<div class="title-row"><div class="t-num" style="background:${color}">0${i+1}</div><div class="t-txt">${esc(t)}</div></div>`).join('');
    html += makeSection('제목 (SEO 최적화)', `<div class="title-rows">${rows}</div>`, data.titles.join('\n'));
  }
  if (data.description) html += makeSection('설명란', `<div class="sec-val">${esc(data.description)}</div>`, data.description);
  if (data.timeline?.length) {
    const tlHtml = `<div style="display:flex;flex-direction:column;gap:6px;">${data.timeline.map(t=>`<div style="display:flex;gap:12px;align-items:center;"><span style="font-size:12px;font-weight:700;color:${color};min-width:40px;">${esc(t.time)}</span><span style="font-size:13px;">${esc(t.label)}</span></div>`).join('')}</div>`;
    html += makeSection('타임라인', tlHtml, data.timeline.map(t=>`${t.time} ${t.label}`).join('\n'));
  }
  if (data.hook) html += makeSection('후킹 문구', `<div class="sec-val">${esc(data.hook)}</div>`, data.hook);
  if (data.caption) html += makeSection('본문 캡션', `<div class="sec-val">${esc(data.caption)}</div>`, data.caption);
  if (data.body) html += makeSection('본문', `<div class="sec-val">${esc(data.body)}</div>`, data.body);
  if (data.cta) html += makeSection('CTA 문구', `<div class="sec-val">${esc(data.cta)}</div>`, data.cta);
  if (data.hashtags?.length) {
    const tagsHtml = `<div class="tags">${data.hashtags.map(t=>`<div class="tag">#${esc(t)}</div>`).join('')}</div>`;
    html += makeSection(`해시태그 (${data.hashtags.length}개)`, tagsHtml, data.hashtags.map(t=>`#${t}`).join(' '));
  }
  html += '</div>';
  return html;
}

function doCopy(id) {
  const btn = document.getElementById(id);
  navigator.clipboard.writeText(btn.dataset.v).then(() => {
    btn.textContent = '✓ 복사됨'; btn.classList.add('ok');
    setTimeout(() => { btn.textContent = '복사'; btn.classList.remove('ok'); }, 2000);
  });
}

async function generate() {
  const hospital = document.getElementById('hospital').value.trim();
  const doctor   = document.getElementById('doctor').value.trim();
  const topic    = document.getElementById('topic').value.trim();
  if (!hospital) { document.getElementById('hospital').focus(); return; }
  if (!topic)    { document.getElementById('topic').focus(); return; }
  if (!getApiKey()) { alert('먼저 상단의 API 키를 입력하고 저장해주세요.'); return; }
  _cc = 0;

  const resultArea = document.getElementById('resultArea');
  const tabsEl = document.getElementById('platTabs');
  const panelsEl = document.getElementById('panels');
  resultArea.style.display = 'block';
  tabsEl.innerHTML = ''; panelsEl.innerHTML = '';

  PLATS.forEach((p, i) => {
    const tab = document.createElement('div');
    tab.className = 'plat-tab' + (i===0?' on':'');
    tab.id = `tab_${p.id}`;
    tab.style.setProperty('--pc', p.color);
    tab.innerHTML = `<div class="dot"></div>${p.label}`;
    tab.onclick = () => switchTab(p.id);
    tabsEl.appendChild(tab);
    const panel = document.createElement('div');
    panel.id = `panel_${p.id}`;
    if (i===0) panel.classList.add('show');
    panel.innerHTML = `<div class="loading-box"><div class="spinner"></div><p>생성 중...</p></div>`;
    panelsEl.appendChild(panel);
  });

  resultArea.scrollIntoView({ behavior: 'smooth', block: 'start' });

  for (const p of PLATS) {
    const panel = document.getElementById(`panel_${p.id}`);
    try {
      const raw = await callClaude(buildPrompt(hospital, doctor, topic, p.id), 1500);
      const data = safeParseJSON(raw);
      panel.innerHTML = renderPanel(p.id, p.color, data);
      document.getElementById(`tab_${p.id}`).innerHTML = `<div class="dot"></div>${p.label} ✓`;
    } catch(e) {
      panel.innerHTML = `<div class="err-box">생성 실패: ${esc(e.message)}</div>`;
    }
  }
}

function switchTab(id) {
  document.querySelectorAll('.plat-tab').forEach(t => t.classList.remove('on'));
  document.querySelectorAll('#panels > div').forEach(p => p.classList.remove('show'));
  document.getElementById(`tab_${id}`).classList.add('on');
  document.getElementById(`panel_${id}`).classList.add('show');
}

async function upgradeTopic() {
  const hospital = document.getElementById('hospital').value.trim();
  const doctor   = document.getElementById('doctor').value.trim();
  const topic    = document.getElementById('topic').value.trim();
  if (!topic) { document.getElementById('topic').focus(); return; }
  if (!getApiKey()) { alert('먼저 상단의 API 키를 입력하고 저장해주세요.'); return; }

  const btn = document.getElementById('upgradeBtn');
  const textarea = document.getElementById('topic');
  btn.disabled = true; btn.textContent = '업그레이드 중...';
  textarea.style.opacity = '0.5';

  try {
    const prompt = `당신은 의료 SNS 마케팅 전문가입니다. 아래 콘텐츠 주제를 SNS 카피 작성에 더 유용하도록 업그레이드해주세요.
병원명: ${hospital||'미입력'} / 원장: ${doctor||'미입력'} / 원본 주제: ${topic}
기준: 핵심 메시지 구체화, 타겟 시청자가 궁금해할 세부 내용 추가, SEO 핵심 키워드 2~3개 포함, 스토리 포인트 제안.
결과는 3~5줄 텍스트만. 제목/마크다운 없이 바로 내용만 출력하세요.`;
    const text = await callClaude(prompt, 500);
    if (text) {
      textarea.value = text;
      textarea.style.borderColor = '#4CAF50';
      setTimeout(() => { textarea.style.borderColor = ''; }, 2000);
    }
  } catch(e) {
    if (e.message !== 'API 키 없음') alert('업그레이드 실패: ' + e.message);
  }

  textarea.style.opacity = '1';
  btn.disabled = false; btn.textContent = '✦ 주제 업그레이드';
}
